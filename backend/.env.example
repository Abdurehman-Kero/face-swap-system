# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration for MAMP
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mamp_root_password
DB_NAME=face_swap_system
DB_PORT=8889

# Security
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=24h

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# AI Engine Path
AI_ENGINE_PATH=../Deep-Live-Cam

# Swap Engine Integration
# mock: keeps web flow working without Python engine
# engine: calls local AI engine service (default URL below)
SWAP_ENGINE_MODE=mock
SWAP_ENGINE_URL=http://127.0.0.1:8765
SWAP_ENGINE_TIMEOUT_MS=5000

# CORS
CLIENT_URL=http://localhost:5173
